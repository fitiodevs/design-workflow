{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://design-workflow.dev/adapter-plan.schema.json",
  "title": "Adapter Plan",
  "description": "Stack-neutral intermediate format emitted by design-workflow skills and consumed by per-stack adapters. v1.0 contract — see docs/adapter-protocol.md.",
  "type": "object",
  "required": ["version", "kind", "actions"],
  "additionalProperties": false,
  "properties": {
    "$schema": {
      "type": "string",
      "format": "uri"
    },
    "version": {
      "type": "string",
      "pattern": "^1\\.[0-9]+$",
      "description": "Plan format version. v1.x line is stable; adapters reject unknown majors."
    },
    "kind": {
      "type": "string",
      "enum": ["palette", "widget-tree", "motion-set"],
      "description": "What this Plan describes. Drives which adapter branch executes."
    },
    "tokens": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "palette":    { "$ref": "#/definitions/paletteTokens" },
        "typography": { "$ref": "#/definitions/typographyTokens" },
        "spacing":    { "$ref": "#/definitions/numericTokens" },
        "radius":     { "$ref": "#/definitions/numericTokens" },
        "motion":     { "$ref": "#/definitions/motionTokens" }
      }
    },
    "widgets": {
      "type": "array",
      "items": { "$ref": "#/definitions/widgetNode" }
    },
    "actions": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/definitions/action" }
    }
  },
  "allOf": [
    {
      "if": { "properties": { "kind": { "const": "palette" } } },
      "then": {
        "required": ["tokens"],
        "properties": {
          "tokens": { "required": ["palette"] }
        }
      }
    },
    {
      "if": { "properties": { "kind": { "const": "widget-tree" } } },
      "then": { "required": ["widgets"] }
    },
    {
      "if": { "properties": { "kind": { "const": "motion-set" } } },
      "then": {
        "required": ["tokens"],
        "properties": {
          "tokens": { "required": ["motion"] }
        }
      }
    }
  ],
  "definitions": {
    "paletteTokens": {
      "type": "object",
      "description": "Map of semantic role → light/dark hex pair. Roles are stable identifiers like brandDefault, bgBase, feedbackPositive, borderDefault.",
      "minProperties": 1,
      "additionalProperties": {
        "type": "object",
        "required": ["light", "dark"],
        "additionalProperties": false,
        "properties": {
          "light": { "$ref": "#/definitions/hexColor" },
          "dark":  { "$ref": "#/definitions/hexColor" }
        }
      }
    },
    "typographyTokens": {
      "type": "object",
      "description": "Map of role (displayLg, titleMd, bodyDefault, etc) → typography rules.",
      "minProperties": 1,
      "additionalProperties": {
        "type": "object",
        "required": ["fontFamily", "size", "weight"],
        "additionalProperties": false,
        "properties": {
          "fontFamily":    { "type": "string", "minLength": 1 },
          "size":          { "type": "number", "exclusiveMinimum": 0 },
          "weight":        { "type": "integer", "minimum": 100, "maximum": 900, "multipleOf": 100 },
          "lineHeight":    { "type": "number", "exclusiveMinimum": 0 },
          "letterSpacing": { "type": "number" }
        }
      }
    },
    "numericTokens": {
      "type": "object",
      "description": "Map of role → numeric value (px). Used for spacing and radius tokens.",
      "minProperties": 1,
      "additionalProperties": {
        "type": "number",
        "minimum": 0
      }
    },
    "motionTokens": {
      "type": "object",
      "description": "Map of role (fast, normal, slow, etc) → duration + curve.",
      "minProperties": 1,
      "additionalProperties": {
        "type": "object",
        "required": ["durationMs", "curve"],
        "additionalProperties": false,
        "properties": {
          "durationMs": { "type": "integer", "minimum": 0 },
          "curve": {
            "type": "string",
            "enum": [
              "linear",
              "easeIn",
              "easeOut",
              "easeInOut",
              "spring",
              "bounce",
              "anticipate",
              "decelerate"
            ]
          }
        }
      }
    },
    "widgetNode": {
      "type": "object",
      "required": ["type"],
      "additionalProperties": false,
      "properties": {
        "type": {
          "type": "string",
          "enum": [
            "button",
            "text",
            "container",
            "form-group",
            "image",
            "icon",
            "input",
            "select",
            "checkbox",
            "switch",
            "slider",
            "card",
            "list",
            "list-item",
            "divider",
            "spacer",
            "link",
            "badge",
            "avatar",
            "progress"
          ]
        },
        "variant": {
          "type": "string",
          "description": "Type-specific variant identifier (e.g. primary/secondary/ghost for button)."
        },
        "size": {
          "type": "string",
          "enum": ["xs", "sm", "md", "lg", "xl"]
        },
        "props": {
          "type": "object",
          "description": "Type-specific data (label, src, placeholder, etc). No schema constraint at the contract level — each adapter validates per type."
        },
        "children": {
          "type": "array",
          "items": { "$ref": "#/definitions/widgetNode" }
        }
      }
    },
    "action": {
      "type": "object",
      "required": ["op", "role", "intent"],
      "additionalProperties": false,
      "properties": {
        "op": {
          "type": "string",
          "enum": ["write", "append", "patch"]
        },
        "role": {
          "type": "string",
          "enum": [
            "palette",
            "spacing",
            "radius",
            "typography",
            "motion",
            "widget-tree",
            "design-tokens"
          ]
        },
        "intent": {
          "type": "string",
          "enum": ["tokens", "component", "config", "doc-summary"]
        },
        "name": {
          "type": "string",
          "description": "Required for `intent: component` — the component / widget name (PascalCase).",
          "pattern": "^[A-Z][A-Za-z0-9]*$"
        }
      },
      "allOf": [
        {
          "if": { "properties": { "intent": { "const": "component" } } },
          "then": { "required": ["name"] }
        }
      ]
    },
    "hexColor": {
      "type": "string",
      "pattern": "^#([0-9a-fA-F]{3}|[0-9a-fA-F]{6}|[0-9a-fA-F]{8})$",
      "description": "Hex color: #rgb, #rrggbb, or #rrggbbaa."
    }
  }
}
